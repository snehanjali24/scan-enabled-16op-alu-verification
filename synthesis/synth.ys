#=========================================================
# 4-Bit ALU with Scan DFT
# RTL Synthesis Script
# Tool  : Yosys 0.67
# Author: Akhilesh
#=========================================================

#---------------------------------------------------------
# Read RTL Source Files
#---------------------------------------------------------
read_verilog scan_dff.v
read_verilog scan_chain.v
read_verilog alu_scan.v

#---------------------------------------------------------
# Set Top Module
#---------------------------------------------------------
hierarchy -check -top alu_scan

#---------------------------------------------------------
# Check Design
#---------------------------------------------------------
check

#---------------------------------------------------------
# Convert Processes
#---------------------------------------------------------
proc

#---------------------------------------------------------
# Optimize Logic
#---------------------------------------------------------
opt

#---------------------------------------------------------
# Memory Optimization
#---------------------------------------------------------
memory

#---------------------------------------------------------
# Additional Optimization
#---------------------------------------------------------
opt

#---------------------------------------------------------
# FSM Optimization
#---------------------------------------------------------
fsm

#---------------------------------------------------------
# Optimize Again
#---------------------------------------------------------
opt

#---------------------------------------------------------
# Technology Mapping
#---------------------------------------------------------
techmap

#---------------------------------------------------------
# Final Optimization
#---------------------------------------------------------
opt

#---------------------------------------------------------
# Generate Statistics
#---------------------------------------------------------
stat

#---------------------------------------------------------
# Generate Gate-Level Netlist
#---------------------------------------------------------
write_verilog alu_scan_synth.v